    "expire_days": 7
  },
  "params": {
    "contact_form_action": "#",
    "copyright": "(c) Juan Lupión, basado en un diseño de [Zeon Studio](https://zeon.studio)"
  },
  "navigation_button": {
    "enable": true,
    "label": "Github",
